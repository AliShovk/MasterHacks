<?php
function getDatabaseConnection() {
    $envHost = getenv('DB_HOST');
    $isLocalEnvHost = ($envHost === 'localhost' || $envHost === '127.0.0.1');
    if ($envHost !== false && $envHost !== '' && !$isLocalEnvHost) {
        $hosts = [$envHost, 'mysql.e22f1228a3bf.hosting.myjino.ru'];
    } else {
        $hosts = ['mysql.e22f1228a3bf.hosting.myjino.ru', 'localhost'];
    }
    $port = getenv('DB_PORT') ?: '3306';
    $dbname = getenv('DB_NAME') ?: 'j43473032_masterhacks';
    $username = getenv('DB_USER') ?: 'j43473032_master';
    $password = getenv('DB_PASS') ?: '02129261Sxc+';

    $lastException = null;
    foreach ($hosts as $host) {
        try {
            $dsn = "mysql:host={$host};";
            if ($port !== '') {
                $dsn .= "port={$port};";
            }
            $dsn .= "dbname={$dbname};charset=utf8mb4";

            $pdo = new PDO(
                $dsn,
                $username,
                $password,
                [
                    PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
                    PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
                    PDO::ATTR_EMULATE_PREPARES => false
                ]
            );
            return $pdo;
        } catch (PDOException $e) {
            $lastException = $e;
        }
    }

    if ($lastException) {
        throw $lastException;
    }

    throw new PDOException('Database connection failed');
}

